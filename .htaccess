RewriteEngine On
RewriteBase /pro_enroll_api/

# Forward Authorization to PHP (Apache strips it under Alias/FPM without this).
RewriteCond %{HTTP:Authorization} ^(.+)$
RewriteRule .* - [E=HTTP_AUTHORIZATION:%1]

# Note: Options/DirectoryIndex belong in deploy/apache-pro-enroll.conf (not here — causes 500 if AllowOverride lacks Options)

# CORS (Flutter web / Postman)
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Authorization, Content-Type, Accept, X-Requested-With"
    Header always set Access-Control-Max-Age "86400"
</IfModule>

# Preflight OPTIONS
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^ - [R=204,L]

# Serve existing files (README.md, test_connection.php, etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Route /v1/* and other paths to front controller
RewriteRule ^ public/index.php [QSA,L]
