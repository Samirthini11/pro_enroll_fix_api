    {
      "name": "01 Get Token (no Bearer)",
      "auth": { "type": "noauth" },
      "item": [
        {
          "name": "Send OTP — Pro-Enroll",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const d = pm.response.json().data || {};",
                  "  if (d.request_id) { pm.environment.set('request_id', d.request_id); pm.collectionVariables.set('request_id', d.request_id); }",
                  "  if (d.debug_otp) { pm.environment.set('otp', d.debug_otp); pm.collectionVariables.set('otp', d.debug_otp); }",
                  "} catch (e) {}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone_e164\": \"{{phone_e164}}\",\n  \"mode\": \"sign_up\"\n}"
            },
            "url": "{{base_url}}/v1/auth/otp/send"
          }
        },
        {
          "name": "Verify OTP — Pro-Enroll",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const d = pm.response.json().data || {};",
                  "  if (d.access_token) { pm.environment.set('access_token', d.access_token); pm.collectionVariables.set('access_token', d.access_token); }",
                  "  if (d.refresh_token) { pm.environment.set('refresh_token', d.refresh_token); pm.collectionVariables.set('refresh_token', d.refresh_token); }",
                  "} catch (e) {}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"request_id\": \"{{request_id}}\",\n  \"otp\": \"{{otp}}\",\n  \"mode\": \"sign_up\"\n}"
            },
            "url": "{{base_url}}/v1/auth/otp/verify"
          }
        },
        {
          "name": "Send OTP — Pro-Fix Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const d = pm.response.json().data || {};",
                  "  if (d.request_id) { pm.environment.set('request_id', d.request_id); }",
                  "  if (d.debug_otp) { pm.environment.set('otp', d.debug_otp); }",
                  "} catch (e) {}"
                ]
