          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone_e164\": \"{{phone_e164}}\",\n  \"mode\": \"sign_up\",\n  \"app\": \"pro_fix_customer\"\n}"
            },
            "url": "{{base_url}}/v1/auth/otp/send"
          }
        },
        {
          "name": "Verify OTP — Pro-Fix Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const d = pm.response.json().data || {};",
                  "  if (d.access_token) { pm.environment.set('access_token', d.access_token); pm.collectionVariables.set('access_token', d.access_token); }",
                  "  if (d.refresh_token) { pm.environment.set('refresh_token', d.refresh_token); pm.collectionVariables.set('refresh_token', d.refresh_token); }",
                  "} catch (e) {}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"request_id\": \"{{request_id}}\",\n  \"otp\": \"{{otp}}\",\n  \"mode\": \"sign_up\",\n  \"app\": \"pro_fix_customer\",\n  \"full_name\": \"Test Customer\"\n}"
            },
            "url": "{{base_url}}/v1/auth/otp/verify"
          }
        },
        {
          "name": "Firebase Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const d = pm.response.json().data || {};",
                  "  if (d.access_token) { pm.environment.set('access_token', d.access_token); pm.collectionVariables.set('access_token', d.access_token); }",
                  "  if (d.refresh_token) { pm.environment.set('refresh_token', d.refresh_token); pm.collectionVariables.set('refresh_token', d.refresh_token); }",
                  "} catch (e) {}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_token\": \"<firebase_id_token>\",\n  \"mode\": \"sign_up\"\n}"
            },
            "url": "{{base_url}}/v1/auth/firebase/session"
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const d = pm.response.json().data || {};",
                  "  if (d.access_token) { pm.environment.set('access_token', d.access_token); pm.collectionVariables.set('access_token', d.access_token); }",
                  "  if (d.refresh_token) { pm.environment.set('refresh_token', d.refresh_token); pm.collectionVariables.set('refresh_token', d.refresh_token); }",
                  "} catch (e) {}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": "{{base_url}}/v1/auth/refresh"
          }
        }
      ]
