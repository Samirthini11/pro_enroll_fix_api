APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080

# MySQL — DB_HOST = database IP (127.0.0.1 on VPS). NOT http://98.93.105.128/
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=pro_enroll
DB_USER=proadmin
DB_PASS=Krishna@123

# Remote VPS (98.93.105.128) — copy .env.remote to server as .env
# APP_URL=http://98.93.105.128/pro_enroll_api
# phpMyAdmin: http://98.93.105.128/phpmyadmin/

# Admin approval app (Flutter)
ADMIN_EMAIL=admin@proenroll.in
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin User
ADMIN_ROLE=ops

# JWT (change JWT_SECRET in production)
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_TTL_SECONDS=604800
JWT_REFRESH_TTL_SECONDS=2592000

# Firebase Admin SDK — REQUIRED for server push (FCM HTTP v1 + OAuth access token).
# NOT the same as google-services.json (Android client only).
# Download: Firebase Console → Project settings → Service accounts → Generate new private key
# Save as: config/firebase-service-account.json (gitignored — upload manually to VPS)
FIREBASE_CREDENTIALS=config/firebase-service-account.json
FIREBASE_PROJECT_ID=proenroll-4ff13
# FIREBASE_AUTH_DISABLED=true

VISIT_COMMISSION_PERCENT=5
FREE_BOOKING_LIMIT=5
HOLD_PRO_AFTER_FREE_LIMIT=1

OTP_FROM_EMAIL=noreply@proenroll.local
OTP_MAIL_TO=you@example.com
OTP_EXPIRY_SECONDS=600
# Return OTP in API response when APP_DEBUG=true (local only)
OTP_DEBUG_RETURN=true
